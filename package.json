{
  "name": "missionthread-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Auditable, AI-assisted program-control platform for complex hardware-and-software programs.",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @missionthread/web",
    "build": "npm run build --workspace @missionthread/web",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "npm run db:generate --workspace @missionthread/core",
    "db:validate": "npm run db:validate --workspace @missionthread/core",
    "db:migrate": "npm run db:migrate --workspace @missionthread/core",
    "db:seed:destructive": "node scripts/with-destructive-auth.mjs npm run db:seed:internal --workspace @missionthread/core",
    "db:reset:test": "node scripts/with-destructive-auth.mjs npm run db:reset:test:internal --workspace @missionthread/core",
    "smoke:test": "npm run build --workspace @missionthread/web && npm run smoke --workspace @missionthread/web"
  },
  "devDependencies": {
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@prisma/engines@7.8.0": true,
    "fsevents@2.3.3": true
  }
}
