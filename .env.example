# Node environment
NODE_ENV=development

# PostgreSQL — Docker Compose maps the container to host port 55432 to avoid
# colliding with a local Postgres that may already be running on 5432.
# See docs/DECISIONS.md (2026-07-17) and docker-compose.yml.
DATABASE_URL="postgresql://missionthread:missionthread_local_dev_password@localhost:55432/missionthread_dev"

# Auth.js (v5). Generate a real secret locally with: npx auth secret
AUTH_SECRET="replace-with-a-generated-secret"

# AI provider mode — exactly "mock" or "live" (packages/core/src/ai/provider-factory.ts
# rejects anything else, including uppercase/whitespace variants or an unset
# value). "mock" is deterministic, needs no API key, and is required for CI
# and demos. "live" calls the real OpenAI Responses API and needs
# OPENAI_API_KEY/OPENAI_MODEL below.
AI_MODE=mock

# Only required when AI_MODE=live. Never commit a real key here — this file
# is an example only. Server-side only; never sent to the browser.
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Destructive commands (npm run db:seed:dev:destructive, npm run db:reset:test)
# require ALLOW_DESTRUCTIVE_DATABASE_OPERATION=true. Deliberately NOT set
# here: those npm scripts supply it themselves, only for the one child
# process that needs it, via scripts/with-destructive-auth.mjs — see
# packages/core/src/db-safety.ts. Setting it here would make it permanently
# active for every process that reads this file, defeating the point of
# requiring an explicit, per-invocation opt-in.
