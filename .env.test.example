# Dedicated test environment — never point this at the dev or a production
# database. The database name must contain "test"; db:reset:test refuses to
# run otherwise (see packages/core/scripts/reset-test-db.ts).
NODE_ENV=test

DATABASE_URL="postgresql://missionthread:missionthread_local_dev_password@localhost:55432/missionthread_test"
TEST_DATABASE_URL="postgresql://missionthread:missionthread_local_dev_password@localhost:55432/missionthread_test"

AUTH_SECRET="test-secret-not-for-production"
AI_MODE=mock

# Required for packages/core/scripts/reset-test-db.ts and the seed script's
# clear-and-reseed step — see packages/core/src/db-safety.ts. This flag is
# only one of several checks (host and database-name allowlists also apply).
ALLOW_DESTRUCTIVE_DATABASE_OPERATION=true
