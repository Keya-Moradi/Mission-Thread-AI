# Dedicated test environment — never point this at the dev or a production
# database. Destructive test commands (npm run db:reset:test) require an
# exact approved (host, port, database) target — see
# packages/core/src/db-safety.ts — not merely a database name that contains
# "test". The only locally-approved test target is
# localhost:55432/missionthread_test (or 127.0.0.1:55432/missionthread_test);
# CI uses a separate, CI-only target that requires CI=true. Always invoke
# destructive operations through their deliberately named commands
# (npm run db:reset:test, npm run db:seed:destructive), never by hand-setting
# ALLOW_DESTRUCTIVE_DATABASE_OPERATION.
NODE_ENV=test

DATABASE_URL="postgresql://missionthread:missionthread_local_dev_password@localhost:55432/missionthread_test"
TEST_DATABASE_URL="postgresql://missionthread:missionthread_local_dev_password@localhost:55432/missionthread_test"

AUTH_SECRET="test-secret-not-for-production"
AI_MODE=mock

# Deliberately NOT set here — see .env.example for why. The npm scripts
# that need this supply it only for their own child process.
