{
  "name": "@missionthread/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src prisma/seed.ts scripts prisma.config.ts vitest.config.ts",
    "test": "vitest run",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:seed:internal": "tsx prisma/seed.ts",
    "db:reset:test:internal": "tsx scripts/reset-test-db.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7",
    "@prisma/client": "^7",
    "openai": "^6",
    "zod": "^4"
  },
  "devDependencies": {
    "dotenv": "^16",
    "prisma": "^7",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4"
  }
}
